# ══════════════════════════════════════════
# HammaBop — Environment Variables
# Nusxa: cp .env.example .env
# ══════════════════════════════════════════

# ─── Supabase (frontend) ───────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Telegram ──────────────────────────────
VITE_TELEGRAM_BOT_USERNAME=hammabop_bot
VITE_TELEGRAM_CLIENT_ID=your_telegram_app_id

# ─── Server (backend) ─────────────────────
PORT=3001
NODE_ENV=production

# Supabase server-side (maxfiy!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram bot
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFGGHHIIJJyour-bot-token

# Admin Telegram ID'lar (vergul bilan ajrating)
ADMIN_TELEGRAM_IDS=5064451675

# Ilova URL
APP_URL=https://aigate.uz

# CORS (production'da to'ldirish shart)
ALLOWED_ORIGINS=https://aigate.uz,https://hammabop.uz

# ─── Supabase Edge Functions env ──────────
# (Supabase Dashboard > Project Settings > Edge Functions > Secrets)
# TELEGRAM_BOT_TOKEN=...
# ADMIN_TELEGRAM_IDS=...
# APP_URL=https://aigate.uz
# PAYMENT_CARD_NUMBER=8600 XXXX XXXX XXXX
# PAYMENT_CARD_HOLDER=ABDULMALIK ERALIYEV

# ─── To'lov tizimlari (kelajak) ───────────
# CLICK_SERVICE_ID=
# CLICK_MERCHANT_ID=
# PAYME_MERCHANT_ID=
# ALIF_API_KEY=
# UZUM_API_KEY=
